{
  "name": "xeno-bot",
  "version": "1.10.0",
  "description": "Scalable discord.js v14 bot scaffold",
  "main": "src/index.js",
  "scripts": {
    "start": "NODE_ENV=production NODE_OPTIONS=--max-old-space-size=1024 node bin/shard.js",
    "start:single": "NODE_ENV=production NODE_OPTIONS=--max-old-space-size=1024 node src/index.js",
    "start:dev": "AUTO_START_REDIS=1 NODE_ENV=development node src/index.js",
    "dev": "AUTO_START_REDIS=1 NODE_ENV=development nodemon",
    "dev:shards": "AUTO_START_REDIS=1 NODE_ENV=development node bin/shard.js",
    "deploy-dev-commands": "BOT_PROFILE=dev node bin/deploy-commands.js",
    "clear-public-commands": "BOT_PROFILE=public CLEAR_GLOBAL_COMMANDS=true node bin/deploy-commands.js",
    "deploy:public": "BOT_PROFILE=public node bin/deploy-commands.js",
    "deploy-commands": "node bin/deploy-commands.js",
    "update-topgg-commands": "node scripts/update-topgg-commands.js",
    "cleanup-shop-items": "node scripts/remove-shop-items.js",
    "migrate:facehuggers:dry": "node scripts/migrate-facehuggers-to-xenos.js",
    "migrate:facehuggers": "node scripts/migrate-facehuggers-to-xenos.js --apply",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint --fix src --ext .js",
    "redis:status": "node bin/check-redis.js"
  },
  "dependencies": {
    "@discordjs/builders": "^2.0.0-dev.1771286636-ccce987fa",
    "@discordjs/rest": "^0.4.1",
    "@sentry/node": "^7.16.0",
    "bullmq": "^2.3.2",
    "cors": "^2.8.5",
    "discord-api-types": "^0.38.42",
    "discord.js": "^15.0.0-pr-10758.1765463096-d081e1706",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "helmet": "^6.0.0",
    "ioredis": "^5.3.2",
    "knex": "^3.1.0",
    "luxon": "^3.7.2",
    "mysql2": "^3.19.1",
    "pg": "^8.20.0",
    "session-file-store": "^1.5.0",
    "sqlite3": "^6.0.1",
    "winston": "^3.8.2",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "module-alias": "^2.2.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1"
  },
  "_moduleAliases": {
    "@utils": "src/utils",
    "@models": "src/models"
  },
  "engines": {
    "node": ">=16.9.0"
  }
}
