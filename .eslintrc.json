{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "globals": {
    "require": "readonly",
    "module": "writable",
    "process": "readonly",
    "console": "readonly",
    "__dirname": "readonly",
    "__filename": "readonly",
    "Buffer": "readonly"
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "overrides": [
    {
      "files": ["src/**/*.js", "bin/**/*.js", "scripts/**/*.js", "tools/**/*.js"],
      "parserOptions": {
        "sourceType": "script"
      },
      "env": {
        "commonjs": true
      }
    }
  ],
  "rules": {
    "no-console": "off",
    "no-unused-vars": "off",
    "no-useless-assignment": "off",
    "no-useless-escape": "off"
  }
}
